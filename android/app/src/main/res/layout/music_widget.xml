<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:clickable="true"
    android:focusable="true"
    android:clipToPadding="false">

    <!-- Cover Art (Füllt die linke Seite komplett aus) -->
    <ImageView
        android:id="@+id/widget_cover"
        android:layout_width="110dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="Album Art" />

    <!-- Content Bereich rechts vom Cover -->
    <LinearLayout
        android:id="@+id/content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/widget_cover"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Title and Artist -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Song Title"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist - Album"
            android:textColor="#8E8E93"
            android:textSize="15sp"
            android:ellipsize="end"
            android:maxLines="1"
            android:layout_marginTop="2dp" />

        <!-- Spacer (Verwendung eines erlaubten View-Typs für RemoteViews) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Controls (Gleichmäßig verteilt) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/widget_prev"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#FA243C" />

            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.2"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:tint="#FA243C" />

            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:tint="#FA243C" />
        </LinearLayout>

        <!-- Progress & Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/widget_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#FA243C"
                android:progressBackgroundTint="#38383A" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/widget_time_current"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#8E8E93"
                    android:textSize="11sp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/widget_time_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="#8E8E93"
                    android:textSize="11sp"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
